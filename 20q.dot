// ABOUTME: A 20 Questions game implemented as a mammoth DOT pipeline.
// ABOUTME: The AI asks yes/no questions to guess what the human is thinking of.

digraph twenty_questions {
  graph [
    label="20q — Twenty Questions Game",
    goal="Play 20 Questions: the human thinks of something, the AI asks yes/no questions and tries to guess what it is within 20 questions.",
    rankdir=LR,
    default_max_retry=1,
    retry_target="ThinkQuestion",
    default_fidelity="summary:high",
    model_stylesheet="
      * { llm_model: gpt-5-mini; llm_provider: openai; reasoning_effort: medium; }
    "
  ];

  // ============================================================
  // TERMINALS
  // ============================================================
  Start [shape=Mdiamond, label="Start"];
  Exit  [shape=Msquare,  label="Exit"];

  // ============================================================
  // WELCOME & SETUP
  // ============================================================

  ResetGame [
    shape=parallelogram,
    label="Reset Game",
    tool_command="#!/bin/sh\nrm -f 20q-log.md\nprintf 'reset'"
  ];

  Welcome [
    shape=box,
    label="Welcome",
    goal_gate=true,
    retry_target="Welcome",
    prompt="Welcome the human to 20 Questions! Explain the rules briefly: they think of something (person, place, thing, or concept), and you get 20 yes/no questions to figure it out."
  ];

  HumanReady [
    shape=hexagon,
    label="Ready to play?",
    mode="yes_no",
    type="wait.human",
    prompt="Think of something — a person, place, thing, or concept. Got it?

[Y] Ready — I have something in mind
[N] Not yet — give me a moment"
  ];

  // ============================================================
  // QUESTION LOOP — all state is in context, no files needed
  // ============================================================

  ThinkQuestion [
    shape=box,
    label="Think",
    goal_gate=true,
    retry_target="ThinkQuestion",
    prompt="You are playing 20 Questions. You will make EXACTLY 2 tool calls, then STOP.

## EXACT TOOL CALL SEQUENCE — no more, no less:

TOOL CALL 1: Read `20q-log.md`. If it does not exist, that is fine — the game just started.

Now THINK (no tool call): Look at the log. The human's last answer is carried in context: outcome=success means their answer was YES, outcome=fail means NO. Count how many questions have been asked.

TOOL CALL 2: Write `20q-log.md` with your update:
- If this is NOT the first question: add 'Answer: YES' or 'Answer: NO' to the last question based on the human's answer from context.
- If 20 questions reached OR you are >80% confident: add your guess line 'GUESS: [your guess]'. End with outcome=fail.
- Otherwise: append exactly ONE new question line like 'Question N: [your question]?'. End with outcome=success.

STOP. YOU ARE DONE. DO NOT MAKE ANY MORE TOOL CALLS.

## ABSOLUTE RULES:
- You get exactly 2 tool calls: one read, one write. NOTHING ELSE.
- NEVER answer your own question. You do NOT know the answer.
- NEVER ask more than one question per turn.
- NEVER write Answer lines for the question you just asked — you must WAIT for the human.
- After your write, STOP IMMEDIATELY. Do not read the file again.

outcome=success if you asked a question
outcome=fail if you are guessing"
  ];

  AskQuestion [
    shape=hexagon,
    label="Answer the Question",
    mode="yes_no",
    type="wait.human",
    prompt="Answer the question above.

[Y] Yes
[N] No"
  ];

  // ============================================================
  // GUESSING
  // ============================================================

  MakeGuess [
    shape=box,
    label="Present Guess",
    goal_gate=true,
    retry_target="MakeGuess",
    prompt="You just decided to guess. Read `20q-log.md` for the full Q&A history. Present your guess confidently to the human. Walk through the key yes/no clues that led you to this answer."
  ];

  HumanJudge [
    shape=hexagon,
    label="Did I get it right?",
    mode="yes_no",
    type="wait.human",
    prompt="Was the guess correct?

[Y] Yes — you got it!
[N] No — that is not it"
  ];

  WrongGuess [
    shape=box,
    label="Wrong Guess",
    goal_gate=true,
    retry_target="WrongGuess",
    prompt="Your guess was wrong. Read `20q-log.md` and count questions. If fewer than 20 remain, say 'Back to the drawing board!' and end with outcome=success. If all 20 used, end with outcome=fail.

outcome=success if questions remain
outcome=fail if all 20 used"
  ];

  // ============================================================
  // ENDGAME
  // ============================================================

  FinalGuess [
    shape=box,
    label="Final Guess",
    goal_gate=true,
    retry_target="FinalGuess",
    prompt="You have used all 20 questions and your earlier guess was wrong. Read `20q-log.md` for the full Q&A history. Make one last guess. Present it with your reasoning."
  ];

  HumanJudgeFinal [
    shape=hexagon,
    label="Final guess — correct?",
    mode="yes_no",
    type="wait.human",
    prompt="Was the final guess correct?

[Y] Yes — you got it at the buzzer!
[N] No — I stumped you!"
  ];

  Victory [
    shape=box,
    label="Victory!",
    goal_gate=true,
    retry_target="Victory",
    prompt="You guessed correctly! Celebrate! Read `20q-log.md` to count how many questions it took. Be enthusiastic but not obnoxious."
  ];

  Defeat [
    shape=box,
    label="Defeat",
    goal_gate=true,
    retry_target="Defeat",
    prompt="You lost! Ask the human what they were thinking of. Be a gracious loser. Read `20q-log.md` and reflect on where your questioning strategy went wrong."
  ];

  // ============================================================
  // PLAY AGAIN
  // ============================================================

  PlayAgain [
    shape=hexagon,
    label="Play Again?",
    mode="yes_no",
    type="wait.human",
    prompt="Want to play another round?

[Y] Yes — let us go again!
[N] No — good game"
  ];

  // ============================================================
  // EDGES
  // ============================================================

  Start -> ResetGame;
  ResetGame -> Welcome;
  Welcome -> HumanReady;

  HumanReady -> ThinkQuestion [label="[Y] Ready", condition="outcome=success", weight=2];
  HumanReady -> HumanReady [label="[N] Not yet", condition="outcome=fail"];

  // Question loop — ThinkQuestion routes based on its own outcome
  ThinkQuestion -> AskQuestion [label="asking", condition="outcome=success", weight=2];
  ThinkQuestion -> MakeGuess [label="guessing", condition="outcome=fail"];

  // Human answers yes/no, loops back
  AskQuestion -> ThinkQuestion [label="[Y] Yes", condition="outcome=success", weight=2];
  AskQuestion -> ThinkQuestion [label="[N] No", condition="outcome=fail"];

  // Guess flow
  MakeGuess -> HumanJudge;
  HumanJudge -> Victory [label="[Y] Correct!", condition="outcome=success", weight=2];
  HumanJudge -> WrongGuess [label="[N] Wrong", condition="outcome=fail"];

  // Wrong guess — continue or final
  WrongGuess -> ThinkQuestion [label="keep going", condition="outcome=success", weight=2];
  WrongGuess -> FinalGuess [label="out of questions", condition="outcome=fail"];

  // Final guess
  FinalGuess -> HumanJudgeFinal;
  HumanJudgeFinal -> Victory [label="[Y] Got it!", condition="outcome=success", weight=2];
  HumanJudgeFinal -> Defeat [label="[N] Stumped", condition="outcome=fail"];

  // End
  Victory -> PlayAgain;
  Defeat -> PlayAgain;

  PlayAgain -> ResetGame [label="[Y] Again!", condition="outcome=success", weight=2];
  PlayAgain -> Exit [label="[N] Done", condition="outcome=fail"];
}
