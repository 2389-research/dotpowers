// ABOUTME: Ultra-minimal AI build pipeline — fastest path from spec to shipped code.
// ABOUTME: No brainstorm, no design doc, no multi-round planning. Read spec, plan, implement, test, ship.

digraph speedrun {
  graph [
    label="speedrun — Spec to Shipped Code, Maximum Velocity",
    goal="Given a project with a spec or description already present, produce working software as fast as possible: single-pass plan, bulk implementation, test, ship. Fully headless, no human gates.",
    rankdir=LR,
    default_max_retry=2,
    retry_target="Implement",
    default_fidelity="summary:high",
    model_stylesheet="
      * { llm_model: gpt-5.4; llm_provider: openai; reasoning_effort: high; }
    "
  ];

  // ============================================================
  // TERMINALS
  // ============================================================
  Start [shape=Mdiamond, label="Start"];
  Exit  [shape=Msquare,  label="Exit"];

  // ============================================================
  // PHASE 1 — READ SPEC
  // ============================================================

  ReadSpec [
    shape=box,
    label="Read Spec",
    goal_gate=true,
    retry_target="ReadSpec",
    fidelity="full",
    prompt="You are working in `run.working_dir`.

## Task
Read EVERYTHING in the working directory. Absorb all context — specs, READMEs, existing code, config files, idea docs, TODOs, anything.

## Process
1. List all files recursively: find . -type f | grep -v '.git/' | head -100
2. Read every file that could describe the project (*.md, README*, SPEC*, idea*, *.txt, etc.)
3. Read any existing source code to understand current state
4. Determine: What are we building? What already exists? What needs to be done?

## Output
Write a concise summary to docs/plans/spec-digest.md:
- **What we're building:** (1-3 sentences)
- **What already exists:** (list files and their purpose)
- **What needs to be done:** (bullet list of deliverables)
- **Tech stack:** (language, framework, key deps — infer from existing files or spec)
- **Test framework:** (infer or choose appropriate one)

mkdir -p docs/plans before writing.
Be ruthlessly concise. This is a speedrun.
"
  ];

  // ============================================================
  // PHASE 2 — SINGLE-PASS PLAN
  // ============================================================

  QuickPlan [
    shape=box,
    label="Quick Plan",
    goal_gate=true,
    retry_target="QuickPlan",
    fidelity="full",
    prompt="You are working in `run.working_dir`.

## Task
Create a minimal implementation plan. Single pass. No audit loop. Speed is everything.

## Context
Read docs/plans/spec-digest.md for the project summary.

## Plan Format
Start with a one-line goal and tech stack summary, then list tasks as checkboxes:

- [ ] task-001: Title
  **Files:** paths to create/modify
  **Do:** Complete description of what to implement (include test + implementation)

## Rules
- Group related work into BIG tasks — aim for 3-6 tasks total, not 20 tiny ones
- Each task should be a meaningful chunk: 'implement the core module with tests' not 'create file X'
- Include setup as task-001 (project init, deps, tooling)
- Include a final 'wire everything together and verify' task
- Every task includes both tests AND implementation — no separate test tasks
- Be specific: exact file paths, exact dep names, exact commands
- YAGNI: only what the spec asks for, nothing more

## Output
Write to docs/plans/plan.md.
git add docs/plans/ && git commit -m 'docs(plan): add speedrun implementation plan'
"
  ];

  // ============================================================
  // PHASE 3 — SETUP
  // ============================================================

  SetupProject [
    shape=box,
    label="Setup Project",
    goal_gate=true,
    retry_target="SetupProject",
    prompt="You are working in `run.working_dir`.

## Task
Initialize the project based on the plan's tech stack.

## Process
1. Read docs/plans/plan.md — extract tech stack
2. Ensure git repo exists:
   git rev-parse --git-dir >/dev/null 2>&1 || git init
   branch_name=\"speedrun/$(basename $(pwd))\"
   git checkout -b \"$branch_name\" 2>/dev/null || echo \"Already on branch\"
3. Initialize for the language:
   - Python: uv init (if no pyproject.toml), uv add deps, uv add --dev test/lint deps
   - Node: npm init -y, npm install deps
   - Go: go mod init
   - Rust: cargo init
4. Set up linter/formatter (ruff for Python, biome for Node, etc.)
5. Create directory structure per plan
6. Ensure .gitignore covers: .env, .tracker/, __pycache__/, node_modules/, target/, *.bak
7. Run test command to verify setup (even 0 tests is fine)
8. git add -A && git commit -m 'chore(setup): initialize project'

## Success Criteria
- Project initializes cleanly
- Test framework runs
- All committed
"
  ];

  VerifySetup [
    shape=parallelogram,
    label="Verify Setup",
    tool_command="#!/bin/sh\nset -eu\nmkdir -p .tracker\nif [ -f pyproject.toml ]; then\n  uv run pytest --co -q 2>/dev/null || echo 'no-tests-yet'\n  printf 'ready-python'\nelif [ -f package.json ]; then\n  npm test 2>/dev/null || echo 'no-tests-yet'\n  printf 'ready-node'\nelif [ -f go.mod ]; then\n  go build ./... 2>&1 || true\n  printf 'ready-go'\nelif [ -f Cargo.toml ]; then\n  cargo build 2>&1 || true\n  printf 'ready-rust'\nelse\n  printf 'ready-unknown'\nfi"
  ];

  // ============================================================
  // PHASE 4 — BULK IMPLEMENT
  // ============================================================

  Implement [
    shape=box,
    label="Implement Everything",
    goal_gate=true,
    retry_target="Implement",
    max_retries=3,
    fidelity="full",
    prompt="You are working in `run.working_dir`.

## Task
Implement the ENTIRE project in one shot. All tasks from the plan. Tests and implementation together.

## Process
1. Read docs/plans/plan.md for the full plan
2. For each task, in order:
   a. Write tests first (TDD — test must fail before implementation)
   b. Write implementation to make tests pass
   c. Run tests to confirm green
   d. Run linter/formatter and fix issues
3. After ALL tasks are done:
   a. Run the full test suite — everything must pass
   b. Run linter — no errors
   c. Stage and commit per logical chunk:
      git add <specific files> && git commit -m '<type>(<scope>): <description>'
4. Mark completed tasks in docs/plans/plan.md by changing [ ] to [x]

## Rules
- Write REAL tests that verify behavior, not tautological assertions
- No mocks unless absolutely unavoidable (external APIs only)
- Every function body must be complete — never write 'implement the logic here'
- If a test fails unexpectedly, fix the implementation, not the test
- Keep files minimal — don't split into many files unless there's a clear reason
- YAGNI: implement exactly what the spec asks for

## Self-Check Before Finishing
- All tests pass?
- Linter clean?
- All plan tasks marked [x]?
- Code is readable and maintainable?
"
  ];

  // ============================================================
  // PHASE 5 — TEST & FIX LOOP
  // ============================================================

  RunTests [
    shape=parallelogram,
    label="Run Tests",
    tool_command="#!/bin/sh\nset -eu\nif [ -f pyproject.toml ]; then\n  uv run pytest -v 2>&1 | tail -40\n  uv run pytest -q 2>&1 | tail -5\nelif [ -f package.json ]; then\n  npm test 2>&1 | tail -40\nelif [ -f go.mod ]; then\n  go test ./... -v 2>&1 | tail -40\nelif [ -f Cargo.toml ]; then\n  cargo test 2>&1 | tail -40\nelse\n  echo 'no-test-framework'\nfi\necho '---'\nif [ -f pyproject.toml ]; then\n  uv run pytest -q 2>&1 | grep -E '(passed|failed|error)' && printf 'DONE' || printf 'NO_RESULTS'\nelif [ -f package.json ]; then\n  printf 'DONE'\nelif [ -f go.mod ]; then\n  printf 'DONE'\nelif [ -f Cargo.toml ]; then\n  printf 'DONE'\nfi"
  ];

  CheckTests [
    shape=parallelogram,
    label="Check Test Results",
    tool_command="#!/bin/sh\nset -eu\nif [ -f pyproject.toml ]; then\n  result=$(uv run pytest -q 2>&1 | tail -1)\nelif [ -f package.json ]; then\n  result=$(npm test 2>&1 | tail -1)\nelif [ -f go.mod ]; then\n  result=$(go test ./... 2>&1 | tail -1)\nelif [ -f Cargo.toml ]; then\n  result=$(cargo test 2>&1 | tail -1)\nelse\n  result='unknown'\nfi\nif echo \"$result\" | grep -qiE '(failed|error|FAIL)'; then\n  printf 'tests_failing'\nelse\n  printf 'tests_passing'\nfi"
  ];

  FixFailures [
    shape=box,
    label="Fix Failures",
    goal_gate=true,
    retry_target="FixFailures",
    max_retries=3,
    prompt="You are working in `run.working_dir`.

## Task
Tests are failing. Fix them. Fast.

## Process
1. Run the full test suite and read the COMPLETE output — every line matters
2. Identify each failing test and the root cause
3. Fix the IMPLEMENTATION, not the tests (unless the test itself has a bug)
4. Run tests again to confirm all green
5. Run linter, fix any issues
6. git add <changed files> && git commit -m 'fix: resolve test failures'

## Rules
- Read the actual error messages carefully
- Fix root causes, not symptoms
- Do NOT delete or skip failing tests
- Do NOT disable functionality to make tests pass
- If you truly cannot fix it after careful analysis, explain what's wrong in your output
"
  ];

  // ============================================================
  // PHASE 6 — SHIP
  // ============================================================

  FinalCheck [
    shape=box,
    label="Final Check",
    goal_gate=true,
    retry_target="FinalCheck",
    prompt="You are working in `run.working_dir`.

## Task
Final sanity check before shipping. Quick and dirty.

## Process
1. Run full test suite — must be green
2. Run linter — must be clean
3. Verify all plan tasks are marked [x] in docs/plans/plan.md
4. Check git status — working tree should be clean
5. Do a quick scan of the code: any obvious bugs, missing error handling, or incomplete stubs?

## Output
If everything looks good, say SHIP_IT.
If there are issues, fix them, commit, and then say SHIP_IT.
"
  ];

  Ship [
    shape=box,
    label="Ship",
    goal_gate=true,
    retry_target="Ship",
    prompt="You are working in `run.working_dir`.

## Task
Ship it. Final commits and summary.

## Process
1. Ensure working tree is clean (commit any stragglers)
2. Write a brief summary to docs/plans/speedrun-summary.md:
   - What was built
   - How to run it
   - How to test it
   - Any known limitations
3. git add docs/plans/speedrun-summary.md && git commit -m 'docs: add speedrun summary'
4. Log the final state:
   echo '--- Final git log ---'
   git log --oneline | head -20
   echo '--- Test results ---'
   # run appropriate test command
   echo '--- Done ---'

## Output
Report what was built and that it's ready for use.
"
  ];

  // ============================================================
  // EDGES
  // ============================================================

  // Phase 1: Read spec
  Start -> ReadSpec [weight=2];

  // Phase 2: Plan
  ReadSpec -> QuickPlan [condition="outcome=success", weight=2];

  // Phase 3: Setup
  QuickPlan -> SetupProject [condition="outcome=success", weight=2];
  SetupProject -> VerifySetup [condition="outcome=success", weight=2];

  // Phase 4: Implement
  VerifySetup -> Implement [weight=2];

  // Phase 5: Test and fix
  Implement -> RunTests [condition="outcome=success", weight=2];
  RunTests -> CheckTests [weight=2];

  CheckTests -> FinalCheck [condition="context.tool_stdout=tests_passing", weight=2];
  CheckTests -> FixFailures [condition="context.tool_stdout=tests_failing"];

  FixFailures -> RunTests [condition="outcome=success", weight=2];
  FixFailures -> Exit [condition="outcome=fail", label="unfixable"];

  // Phase 6: Ship
  FinalCheck -> Ship [condition="outcome=success", weight=2];
  Ship -> Exit [condition="outcome=success", weight=2];

  // Retry edges
  ReadSpec -> ReadSpec [condition="outcome=retry"];
  QuickPlan -> QuickPlan [condition="outcome=retry"];
  SetupProject -> SetupProject [condition="outcome=retry"];
  Implement -> Implement [condition="outcome=retry"];
  FixFailures -> FixFailures [condition="outcome=retry"];
  FinalCheck -> FinalCheck [condition="outcome=retry"];
  Ship -> Ship [condition="outcome=retry"];
}
