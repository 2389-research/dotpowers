// ABOUTME: An interactive fiction / choose-your-own-adventure game as a mammoth DOT pipeline.
// ABOUTME: AI writes branching narrative scenes; the human makes story choices that shape the plot.

digraph story_engine {
  graph [
    label="Story Engine — Choose Your Own Adventure",
    goal="Collaboratively write an interactive story where the AI crafts vivid scenes and the human makes choices that branch the narrative across multiple chapters, culminating in a personalized finale.",
    rankdir=LR,
    default_max_retry=1,
    retry_target="WriteScene",
    default_fidelity="full",
    model_stylesheet="
      * { llm_model: claude-opus-4-6; llm_provider: anthropic; reasoning_effort: high; }
    "
  ];

  // ============================================================
  // TERMINALS
  // ============================================================
  Start [shape=Mdiamond, label="Start"];
  Exit  [shape=Msquare,  label="Exit"];

  // ============================================================
  // SETUP — Reset state and welcome the player
  // ============================================================

  ResetStory [
    shape=parallelogram,
    label="Reset Story",
    tool_command="#!/bin/sh\nrm -f story.md\nprintf 'reset'"
  ];

  Welcome [
    shape=box,
    label="Welcome",
    goal_gate=true,
    retry_target="Welcome",
    prompt="Welcome the human to the Story Engine! Explain the concept:

- You and the human will write an interactive story together
- The AI writes vivid scenes with rich prose
- The human makes choices at key moments that shape the plot
- After several chapters, the story will reach its climax and conclusion
- At the end, a full story summary is generated

Be warm, enthusiastic, and a little theatrical. Set the mood that something epic is about to happen."
  ];

  // ============================================================
  // GENRE SELECTION — human picks the genre and tone
  // ============================================================

  PickGenre [
    shape=hexagon,
    label="Pick a Genre",
    mode="yes_no",
    type="wait.human",
    prompt="What kind of story shall we tell? Pick a genre:

[Y] Fantasy / Sci-Fi — swords, starships, and strange worlds
[N] Mystery / Thriller — secrets, danger, and suspense"
  ];

  PickSubGenre [
    shape=hexagon,
    label="Refine the Tone",
    mode="yes_no",
    type="wait.human",
    prompt="And the tone?

[Y] Epic and serious — high stakes, drama, heroism
[N] Quirky and humorous — absurd twists, witty banter, fun"
  ];

  // ============================================================
  // WORLD SETUP — AI builds the setting and protagonist
  // ============================================================

  SetupWorld [
    shape=box,
    label="Setup World",
    goal_gate=true,
    retry_target="SetupWorld",
    prompt="You are a master storyteller. Based on the human's genre and tone choices from context:

- outcome=success on the genre gate means Fantasy/Sci-Fi; outcome=fail means Mystery/Thriller
- outcome=success on the tone gate means Epic/Serious; outcome=fail means Quirky/Humorous

Create the story foundation. Write to `story.md` using your file tools:

```
# Story Engine Adventure
## Genre: [chosen genre]
## Tone: [chosen tone]
## Setting: [a vivid 2-3 sentence description of the world]
## Protagonist: [name, brief description, a defining trait and a flaw]
## Central Conflict: [the core tension that will drive the story]
---
```

Make the setting specific and atmospheric. The protagonist should feel like a real person with wants and fears. The central conflict should have personal stakes.

After writing the file, briefly summarize what you created to the human."
  ];

  // ============================================================
  // OPENING SCENE — the story begins
  // ============================================================

  WriteOpeningScene [
    shape=box,
    label="Opening Scene",
    goal_gate=true,
    retry_target="WriteOpeningScene",
    prompt="You are a master storyteller. Read `story.md` to get the genre, tone, setting, protagonist, and conflict.

Write Chapter 1 — the opening scene. Append it to `story.md`:

```
## Chapter 1: [evocative title]

[3-5 paragraphs of vivid prose]
```

WRITING GUIDELINES:
- Open in media res or with a striking image
- Establish the protagonist in their world through action, not exposition
- Use sensory details: sounds, smells, textures, light
- Match the tone (epic/serious vs quirky/humorous)
- End on a moment of tension or discovery that demands a choice
- Write in third person, past tense
- Aim for 300-500 words

After the scene, append a choices marker:

```
### Choices:
A) [first option — the bold/risky path]
B) [second option — the cautious/clever path]
C) [third option — the unexpected/creative path]
```

Present the scene and choices to the human in your response."
  ];

  // ============================================================
  // STORY LOOP — human chooses, AI writes, repeat
  // ============================================================

  PresentChoices [
    shape=hexagon,
    label="Make Your Choice",
    mode="yes_no",
    type="wait.human",
    prompt="Which path do you choose?

[Y] Option A — the bold choice
[N] Option B — the cautious choice

(If you want Option C, pick [N] and the story will surprise you either way!)"
  ];

  WriteNextScene [
    shape=box,
    label="Write Next Scene",
    goal_gate=true,
    retry_target="WriteNextScene",
    prompt="You are a master storyteller continuing an interactive story. Read `story.md` to get the full story so far.

The human just made a choice. From context:
- outcome=success means they chose the BOLD path (Option A)
- outcome=fail means they chose the CAUTIOUS path (Option B or C)

First, count the existing chapters (lines starting with '## Chapter'). The next chapter number is one more than the current count.

Append the next chapter to `story.md`:

```
## Chapter N: [evocative title]

[The human chose: [bold/cautious]]

[3-5 paragraphs of vivid prose continuing the story]
```

WRITING GUIDELINES:
- The choice MUST meaningfully affect what happens — no railroad plots
- Raise the stakes with each chapter
- Introduce at least one new element: character, location, revelation, or complication
- Develop the protagonist through their reactions and decisions
- Use callbacks to earlier events when possible
- Maintain genre and tone consistency
- Each chapter should have its own mini-arc (setup, tension, pivot)
- End on a cliffhanger or moment of decision
- 300-500 words of prose

After the scene, append choices:

```
### Choices:
A) [bold/risky path]
B) [cautious/clever path]
C) [unexpected/creative path]
```

Present the scene and choices to the human."
  ];

  CheckChapterCount [
    shape=parallelogram,
    label="Check Chapter Count",
    tool_command="#!/bin/sh\nCOUNT=$(grep -c '## Chapter' story.md)\nif [ \"$COUNT\" -ge 5 ]; then\n  printf 'finale'\n  exit 1\nelse\n  printf 'continue: chapter %s done' \"$COUNT\"\n  exit 0\nfi"
  ];

  // ============================================================
  // FINALE — one last choice, then the climax
  // ============================================================

  FinalChoice [
    shape=hexagon,
    label="The Final Choice",
    mode="yes_no",
    type="wait.human",
    prompt="The story approaches its climax. One last decision...

[Y] Face it head-on — courage, sacrifice, confrontation
[N] Find another way — cunning, alliance, unexpected solution"
  ];

  WriteFinalChapter [
    shape=box,
    label="Write Finale",
    goal_gate=true,
    retry_target="WriteFinalChapter",
    prompt="You are a master storyteller writing the FINALE of an interactive story. Read `story.md` to get the full story.

The human made their final choice:
- outcome=success means FACE IT HEAD-ON (courage/sacrifice)
- outcome=fail means FIND ANOTHER WAY (cunning/unexpected)

Write the final chapter. Append to `story.md`:

```
## Chapter [N]: [epic title — The Final Chapter]

[The human chose: [head-on/another way]]

[5-8 paragraphs — this is the climax and resolution]
```

WRITING GUIDELINES:
- This is the CLIMAX — pull out all the stops
- Resolve the central conflict established in the setup
- The protagonist's defining trait AND flaw should both matter here
- Reference and pay off earlier choices — the human should feel their decisions mattered
- Include a moment of peak tension followed by resolution
- End with a satisfying denouement: where is the protagonist now? What changed?
- Match the tone but allow for emotional depth regardless
- If epic/serious: earn the emotion honestly, no cheap tricks
- If quirky/humorous: the heart beneath the jokes should shine through
- 500-800 words

Do NOT append choices. This is the end.

Present the finale to the human."
  ];

  // ============================================================
  // STORY SUMMARY — generate a recap of the full adventure
  // ============================================================

  StorySummary [
    shape=box,
    label="Story Summary",
    goal_gate=true,
    retry_target="StorySummary",
    prompt="Read `story.md` — the complete interactive story. Generate a story summary and append it:

```
---
## Story Summary

**Title:** [invent a fitting title for this story]
**Genre:** [genre] | **Tone:** [tone]
**Chapters:** [count]

### The Tale
[A 2-3 paragraph narrative summary of the entire story, written like a book jacket blurb. Highlight the key choices the human made and how they shaped the outcome.]

### Character Arc
[1 paragraph on how the protagonist changed from beginning to end]

### Key Choices
[Bullet list of the major decisions and their consequences]

### The Verdict
[A fun, genre-appropriate 1-2 sentence judgment of the human's choices. Were they heroic? Cunning? Chaotic? Give them a title like 'The Reluctant Hero' or 'The Chaos Gremlin'.]
```

Present the full summary to the human. Thank them for playing and tell them this was a unique story that could never be told the same way twice."
  ];

  // ============================================================
  // PLAY AGAIN
  // ============================================================

  PlayAgain [
    shape=hexagon,
    label="Play Again?",
    mode="yes_no",
    type="wait.human",
    prompt="Want to embark on another adventure?

[Y] Yes — a new story awaits!
[N] No — that was a satisfying tale"
  ];

  // ============================================================
  // EDGES
  // ============================================================

  // Setup flow
  Start -> ResetStory;
  ResetStory -> Welcome;
  Welcome -> PickGenre;

  PickGenre -> PickSubGenre [label="[Y] Fantasy/SciFi", condition="outcome=success", weight=2];
  PickGenre -> PickSubGenre [label="[N] Mystery/Thriller", condition="outcome=fail"];

  PickSubGenre -> SetupWorld [label="[Y] Epic/Serious", condition="outcome=success", weight=2];
  PickSubGenre -> SetupWorld [label="[N] Quirky/Humorous", condition="outcome=fail"];

  SetupWorld -> WriteOpeningScene;

  // Opening scene leads to first choice
  WriteOpeningScene -> PresentChoices;

  // Story loop: choice -> write -> check count -> loop or finale
  PresentChoices -> WriteNextScene [label="[Y] Bold path", condition="outcome=success", weight=2];
  PresentChoices -> WriteNextScene [label="[N] Cautious path", condition="outcome=fail"];

  WriteNextScene -> CheckChapterCount;

  CheckChapterCount -> PresentChoices [label="continue", condition="outcome=success", weight=2];
  CheckChapterCount -> FinalChoice [label="finale time", condition="outcome=fail"];

  // Finale flow
  FinalChoice -> WriteFinalChapter [label="[Y] Head-on", condition="outcome=success", weight=2];
  FinalChoice -> WriteFinalChapter [label="[N] Another way", condition="outcome=fail"];

  WriteFinalChapter -> StorySummary;
  StorySummary -> PlayAgain;

  // Play again loop
  PlayAgain -> ResetStory [label="[Y] New adventure!", condition="outcome=success", weight=2];
  PlayAgain -> Exit [label="[N] Farewell", condition="outcome=fail"];
}
